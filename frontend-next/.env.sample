# Mailchimp Marketing API
# API key from Mailchimp Dashboard -> Account -> Extras -> API keys
# The suffix after the dash is your server prefix (e.g. "...-us7" -> us7)
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
# Audience/List ID from Audience -> Settings -> Audience name and defaults
MAILCHIMP_AUDIENCE_ID=
# "subscribed" = single opt-in (immediate). "pending" = double opt-in (confirmation email).
MAILCHIMP_OPTIN_MODE=subscribed

# Basic auth credentials for /admin/* pages
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASS=
